---
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import "@/styles/global.css";
import { siteConfig } from "@/site.config";
import ubuntuSans400Url from "@fontsource/ubuntu-sans/files/ubuntu-sans-latin-400-normal.woff2?url";
import ubuntuSans500Url from "@fontsource/ubuntu-sans/files/ubuntu-sans-latin-500-normal.woff2?url";
import ubuntuSans700Url from "@fontsource/ubuntu-sans/files/ubuntu-sans-latin-700-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description = siteConfig.description, structuredData } = Astro.props;
const pageTitle = title ? `${siteConfig.name} | ${title}` : `${siteConfig.name} | Political Scientist`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://example.com").toString();
const structuredItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/apple-touch-icon.png" type="image/png" />
    <link rel="shortcut icon" href="/apple-touch-icon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" type="image/png" />
    <link rel="preload" href={ubuntuSans400Url} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={ubuntuSans500Url} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={ubuntuSans700Url} as="font" type="font/woff2" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/jpswalsh/academicons@1/css/academicons.min.css"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    {structuredItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <slot name="head" />
  </head>
  <body class="relative flex min-h-screen flex-col">
    <a href="#content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-white">
      Skip to content
    </a>
    <Header />
    <main id="content" class="relative z-10 flex-1">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (() => {
        const PREVIEW_ID = "footnote-preview";
        const VIEWPORT_MARGIN = 12;
        const PREVIEW_GAP = 10;

        const getPreviewElement = () => {
          let preview = document.getElementById(PREVIEW_ID);

          if (preview) {
            return preview;
          }

          preview = document.createElement("div");
          preview.id = PREVIEW_ID;
          preview.className = "footnote-preview";
          preview.setAttribute("role", "tooltip");
          preview.setAttribute("aria-hidden", "true");
          document.body.appendChild(preview);

          return preview;
        };

        const getFootnoteMarkup = (reference) => {
          const href = reference.getAttribute("href");

          if (!href || !href.startsWith("#")) {
            return "";
          }

          const footnoteId = decodeURIComponent(href.slice(1));
          const footnote = document.getElementById(footnoteId);

          if (!footnote) {
            return "";
          }

          const clone = footnote.cloneNode(true);
          clone.querySelectorAll("[data-footnote-backref]").forEach((node) => node.remove());

          if (clone.children.length === 1 && clone.firstElementChild?.tagName === "P") {
            return clone.firstElementChild.innerHTML.trim();
          }

          return clone.innerHTML.trim();
        };

        const positionPreview = (reference, preview) => {
          const rect = reference.getBoundingClientRect();
          const previewWidth = preview.offsetWidth;
          const previewHeight = preview.offsetHeight;
          const centeredLeft = rect.left + rect.width / 2 - previewWidth / 2;
          const left = Math.min(
            Math.max(centeredLeft, VIEWPORT_MARGIN),
            window.innerWidth - previewWidth - VIEWPORT_MARGIN
          );
          const topAbove = rect.top - previewHeight - PREVIEW_GAP;
          const topBelow = rect.bottom + PREVIEW_GAP;
          const top =
            topAbove >= VIEWPORT_MARGIN
              ? topAbove
              : Math.min(topBelow, window.innerHeight - previewHeight - VIEWPORT_MARGIN);

          preview.style.left = `${Math.round(left)}px`;
          preview.style.top = `${Math.round(Math.max(top, VIEWPORT_MARGIN))}px`;
        };

        const initFootnotePreviews = () => {
          const references = document.querySelectorAll("a[data-footnote-ref]");

          if (references.length === 0) {
            return;
          }

          const preview = getPreviewElement();
          let activeReference = null;

          const hidePreview = () => {
            if (activeReference) {
              activeReference.removeAttribute("data-footnote-preview-active");
            }

            activeReference = null;
            preview.dataset.visible = "false";
            preview.setAttribute("aria-hidden", "true");
          };

          const showPreview = (reference) => {
            const markup = getFootnoteMarkup(reference);

            if (!markup) {
              hidePreview();
              return;
            }

            if (activeReference && activeReference !== reference) {
              activeReference.removeAttribute("data-footnote-preview-active");
            }

            activeReference = reference;
            activeReference.setAttribute("data-footnote-preview-active", "true");
            preview.innerHTML = markup;
            preview.dataset.visible = "false";
            preview.setAttribute("aria-hidden", "false");
            positionPreview(reference, preview);
            preview.dataset.visible = "true";
          };

          references.forEach((reference) => {
            if (reference.dataset.footnotePreviewBound === "true") {
              return;
            }

            reference.dataset.footnotePreviewBound = "true";
            reference.addEventListener("mouseenter", () => showPreview(reference));
            reference.addEventListener("mouseleave", hidePreview);
            reference.addEventListener("focus", () => showPreview(reference));
            reference.addEventListener("blur", hidePreview);
          });

          window.addEventListener("scroll", hidePreview, true);
          window.addEventListener("resize", hidePreview);
          document.addEventListener("keydown", (event) => {
            if (event.key === "Escape") {
              hidePreview();
            }
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initFootnotePreviews, { once: true });
        } else {
          initFootnotePreviews();
        }
      })();
    </script>
  </body>
</html>
