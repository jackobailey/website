---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ButtonLink from "@/components/ui/ButtonLink.astro";
import { getPollEntries } from "@/lib/content";
import { formatDate, formatDateTime } from "@/lib/format";

export async function getStaticPaths() {
  const entries = await getPollEntries();
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <section class="section-space">
    <div class="page-shell grid gap-8 lg:grid-cols-[minmax(0,1fr)_300px]">
      <article class="space-y-8">
        <header class="surface surface-strong max-w-reading space-y-5 pt-6 sm:pt-7">
          <p class="eyebrow">Poll update</p>
          <h1 class="headline text-4xl sm:text-5xl">{entry.data.title}</h1>
          <p class="lede">{entry.data.summary}</p>
          <div class="flex flex-wrap gap-4 text-sm text-muted">
            <span>Published {formatDate(entry.data.date)}</span>
            <span>Last refreshed {formatDateTime(entry.data.lastUpdated)}</span>
          </div>
        </header>

        <div class="surface pt-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Top line</p>
          <p class="mt-3 text-base leading-8 text-ink">{entry.data.takeaway}</p>
        </div>

        <div class="surface pt-7 sm:pt-8">
          <div class="prose-editorial">
            <Content />
          </div>
        </div>
      </article>

      <aside class="editorial-sidebar h-fit space-y-4">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Use this with</p>
        <p class="text-sm leading-6 text-ink">
          The main polls page combines the live chart with short written updates so readers can move between visual trend and verbal interpretation.
        </p>
        <div class="pt-1">
          <ButtonLink href="/polls/" variant="secondary">Back to Polls</ButtonLink>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
