---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CopyLinkButton from "@/components/ui/CopyLinkButton.astro";
import TagList from "@/components/ui/TagList.astro";
import { siteConfig } from "@/site.config";
import { getNotesEntries, getTagEntries, getRelatedNotes } from "@/lib/content";
import { formatDate, getReadingTime } from "@/lib/format";
import { buildTagLookup, getTagHref, getTagLabel } from "@/lib/tags";

export async function getStaticPaths() {
  const notes = await getNotesEntries();
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note }
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
const [allNotes, tagEntries] = await Promise.all([getNotesEntries(), getTagEntries()]);
const tagLookup = buildTagLookup(tagEntries);
const relatedNotes = getRelatedNotes(note, allNotes);
const hasRelatedNotes = relatedNotes.length > 0;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: note.data.title,
  description: note.data.summary,
  datePublished: note.data.date.toISOString(),
  dateModified: (note.data.updatedDate ?? note.data.date).toISOString(),
  author: {
    "@type": "Person",
    name: siteConfig.name
  },
  keywords: note.data.tags.join(", ")
};
---

<BaseLayout
  title={note.data.seoTitle ?? note.data.title}
  description={note.data.summary}
  structuredData={structuredData}
>
  <section class="section-space">
    <div class:list={["page-shell gap-8", hasRelatedNotes ? "grid lg:grid-cols-[minmax(0,1fr)_300px]" : ""]}>
      <article class:list={["space-y-8", !hasRelatedNotes && "max-w-4xl"]}>
        <header class="surface surface-strong space-y-5 pt-6 sm:pt-7">
          {note.data.image ? (
            <div class="grid gap-5 sm:grid-cols-[8rem_minmax(0,1fr)] sm:items-center">
              <div class="h-32 w-32 self-center overflow-hidden rounded-3xl ring-1 ring-ink/10">
                <img
                  src={note.data.image}
                  alt={note.data.imageAlt ?? ""}
                  class="block h-full w-full object-cover"
                  loading="eager"
                />
              </div>

              <div class="min-w-0">
                <p class="eyebrow">{formatDate(note.data.date)}</p>
                <h1 class="mt-3 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">{note.data.title}</h1>
                <p class="mt-4 max-w-2xl text-lg leading-8 text-ink">{note.data.summary}</p>
                <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-muted">
                  <span>{getReadingTime(note.body)}</span>
                  {note.data.updatedDate && <span>Updated {formatDate(note.data.updatedDate)}</span>}
                  <CopyLinkButton />
                </div>
                <div class="mt-5">
                  <TagList
                    items={note.data.tags.map((slug) => ({
                      slug,
                      label: getTagLabel(slug, tagLookup),
                      href: getTagHref(slug, "/notes/tags")
                    }))}
                  />
                </div>
              </div>
            </div>
          ) : (
            <>
              <p class="eyebrow">{formatDate(note.data.date)}</p>
              <h1 class="headline text-4xl sm:text-5xl">{note.data.title}</h1>
              <p class="lede">{note.data.summary}</p>
              <div class="flex flex-wrap items-center gap-4 text-sm text-muted">
                <div class="flex flex-wrap items-center gap-4">
                  <span>{getReadingTime(note.body)}</span>
                  {note.data.updatedDate && <span>Updated {formatDate(note.data.updatedDate)}</span>}
                  <CopyLinkButton />
                </div>
              </div>
              <TagList
                items={note.data.tags.map((slug) => ({
                  slug,
                  label: getTagLabel(slug, tagLookup),
                  href: getTagHref(slug, "/notes/tags")
                }))}
              />
            </>
          )}
        </header>

        <div class="surface pt-7 sm:pt-8">
          <div class="prose-editorial">
            <Content />
          </div>
        </div>
      </article>

      {hasRelatedNotes && (
        <aside class="editorial-sidebar space-y-6">
          <div class="space-y-4">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Related notebook entries</p>
            <ul class="space-y-4">
              {relatedNotes.map((entry) => (
                <li class="border-t panel-rule pt-4 first:border-t-0 first:pt-0">
                  <a href={`/notes/${entry.slug}/`} class="font-semibold text-ink hover:text-accent">
                    {entry.data.title}
                  </a>
                  <p class="mt-2 text-sm leading-6 text-ink">{entry.data.summary}</p>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      )}
    </div>
  </section>
</BaseLayout>
