---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/ui/PageIntro.astro";
import TagList from "@/components/ui/TagList.astro";
import { getNotesEntries, getTagEntries } from "@/lib/content";
import { formatDate, getReadingTime } from "@/lib/format";
import { buildTagLookup, getTagCounts, getTagHref, getTagLabel } from "@/lib/tags";

export async function getStaticPaths() {
  const [notes, tags] = await Promise.all([getNotesEntries(), getTagEntries()]);
  const tagCounts = getTagCounts(notes);

  return tags
    .filter((tag) => (tagCounts.get(tag.slug) ?? 0) > 0)
    .map((tag) => ({
      params: { tag: tag.slug },
      props: {
        tag,
        notes: notes.filter((note) => note.data.tags.includes(tag.slug))
      }
    }));
}

const { tag, notes } = Astro.props;
const tagLookup = buildTagLookup(await getTagEntries());
---

<BaseLayout
  title={tag.data.seoTitle ?? `${tag.data.name} notebook entries`}
  description={tag.data.seoDescription ?? tag.data.description}
>
  <PageIntro eyebrow="Tag" title={tag.data.name} description={tag.data.description} />

  <section class="page-shell pb-14 sm:pb-20">
    <div class="grid gap-8 md:grid-cols-2">
      {notes.map((note) => (
        <article class="surface surface-strong pt-6">
          <div class="min-w-0">
            <p class="eyebrow mt-2">{formatDate(note.data.date)}</p>
            <h2 class="mt-3 text-2xl font-semibold tracking-tight text-ink">
              <a href={`/notes/${note.slug}/`} class="hover:text-accent">
                {note.data.title}
              </a>
            </h2>
            <p class="mt-3 text-base leading-8 text-ink">{note.data.summary}</p>
            <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-3 text-sm text-muted">
              <span class="shrink-0">{getReadingTime(note.body)}</span>
              <TagList
                items={note.data.tags.map((slug) => ({
                  slug,
                  label: getTagLabel(slug, tagLookup),
                  href: getTagHref(slug, "/notes/tags")
                }))}
              />
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
