---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="space-y-3">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="text-3xl font-semibold tracking-tight text-ink">{title}</h2>
  {description && <p class="max-w-2xl text-base leading-7 text-muted">{description}</p>}
</div>
