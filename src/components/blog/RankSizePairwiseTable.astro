---
const outcomes = [
  {
    votes: ">",
    seats: ">",
    leftFactor: "+1",
    rightFactor: "+1",
    result: "+1",
    consistent: true,
    group: "positive",
    groupEnd: false
  },
  {
    votes: "<",
    seats: "<",
    leftFactor: "-1",
    rightFactor: "-1",
    result: "+1",
    consistent: true,
    group: "positive",
    groupEnd: true
  },
  {
    votes: ">",
    seats: "<",
    leftFactor: "+1",
    rightFactor: "-1",
    result: "-1",
    consistent: false,
    group: "negative",
    groupEnd: false
  },
  {
    votes: "<",
    seats: ">",
    leftFactor: "-1",
    rightFactor: "+1",
    result: "-1",
    consistent: false,
    group: "negative",
    groupEnd: true
  },
  {
    votes: ">",
    seats: "=",
    leftFactor: "+1",
    rightFactor: "0",
    result: "0",
    consistent: true,
    group: "zero",
    groupEnd: false
  },
  {
    votes: "<",
    seats: "=",
    leftFactor: "-1",
    rightFactor: "0",
    result: "0",
    consistent: true,
    group: "zero",
    groupEnd: false
  },
  {
    votes: "=",
    seats: ">",
    leftFactor: "0",
    rightFactor: "+1",
    result: "0",
    consistent: true,
    group: "zero",
    groupEnd: false
  },
  {
    votes: "=",
    seats: "<",
    leftFactor: "0",
    rightFactor: "-1",
    result: "0",
    consistent: true,
    group: "zero",
    groupEnd: false
  },
  {
    votes: "=",
    seats: "=",
    leftFactor: "0",
    rightFactor: "0",
    result: "0",
    consistent: true,
    group: "zero",
    groupEnd: true
  }
];
---

<div class="not-prose my-10" data-rank-size-pairwise-table>
  <section class="interactive-panel">
    <div class="px-5 pb-2 pt-5 sm:px-6 sm:pb-2 sm:pt-6">
      <p class="eyebrow">The Product of Signs</p>
    </div>

    <div class="overflow-x-auto px-4 pb-5 pt-1 sm:px-6 sm:pb-6 sm:pt-1">
      <table class="w-full table-fixed border-collapse sm:min-w-[38rem]">
        <colgroup>
          <col style="width: 28%" />
          <col style="width: 28%" />
          <col style="width: 30%" />
          <col style="width: 14%" />
        </colgroup>
        <thead class="border-b border-black/8">
          <tr class="text-center text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-black/50 sm:text-[0.82rem] sm:tracking-[0.16em]">
            <th class="px-2 py-3 sm:px-4">Votes</th>
            <th class="px-2 py-3 sm:px-4">Seats</th>
            <th class="px-2 py-3 text-center sm:px-4">Product</th>
            <th class="px-2 py-3 text-center sm:px-4">
              <span class="sm:hidden">R-S</span>
              <span class="hidden sm:inline">Rank-Size</span>
            </th>
          </tr>
        </thead>

        <tbody>
          {
            outcomes.map((outcome) => (
              <tr
                class:list={[
                  "rank-size-table-row text-[#111111] transition duration-200",
                  outcome.groupEnd ? "border-b border-black/14" : "border-b border-black/6"
                ]}
                data-group={outcome.group}
                data-rank-size-state={outcome.consistent ? "consistent" : "inconsistent"}
              >
                <td class="px-2 py-3 text-center text-[0.95rem] font-semibold whitespace-nowrap sm:px-4 sm:text-[0.98rem]">
                  <span class="text-[#FF4136]">Red</span>
                  <span class="px-1.5 text-[#111111] sm:px-2">{outcome.votes}</span>
                  <span class="text-[#0074D9]">Blue</span>
                </td>
                <td class="px-2 py-3 text-center text-[0.95rem] font-semibold whitespace-nowrap sm:px-4 sm:text-[0.98rem]">
                  <span class="text-[#FF4136]">Red</span>
                  <span class="px-1.5 text-[#111111] sm:px-2">{outcome.seats}</span>
                  <span class="text-[#0074D9]">Blue</span>
                </td>
                <td class="px-2 py-3 text-center text-[0.9rem] font-semibold tabular-nums whitespace-nowrap sm:px-4 sm:text-[0.98rem]">
                  <span class="rank-size-product" aria-label={`${outcome.leftFactor} times ${outcome.rightFactor} equals ${outcome.result}`}>
                    <span>{outcome.leftFactor}</span>
                    <span aria-hidden="true">×</span>
                    <span>{outcome.rightFactor}</span>
                    <span aria-hidden="true">=</span>
                    <span>{outcome.result}</span>
                  </span>
                </td>
                <td class="px-2 py-3 text-center text-sm font-medium sm:px-4 sm:text-[0.98rem]">
                  <span
                    class:list={[
                      "rank-size-indicator inline-flex h-6 w-6 items-center justify-center rounded-full sm:h-7 sm:w-7",
                      outcome.consistent ? "text-[#111111]" : "text-accent"
                    ]}
                    aria-hidden="true"
                  >
                    {outcome.consistent ? "✓" : "✗"}
                  </span>
                  <span class="sr-only">
                    {outcome.consistent
                      ? "Consistent with the rank-size principle"
                      : "Inconsistent with the rank-size principle"}
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</div>

<style>
  .rank-size-table-row {
    background: rgba(255, 255, 255, 0);
  }

  .rank-size-table-row[data-group="positive"] {
    background: rgba(17, 17, 17, 0.018);
  }

  .rank-size-table-row[data-group="negative"] {
    background: rgba(247, 111, 92, 0.04);
  }

  .rank-size-table-row[data-group="zero"] {
    background: rgba(17, 17, 17, 0.03);
  }

  .rank-size-indicator {
    background: rgba(17, 17, 17, 0.05);
  }

  .rank-size-product {
    display: inline-grid;
    grid-template-columns: 2.5ch 1.5ch 2.5ch 1.5ch 2.5ch;
    align-items: center;
    justify-items: center;
  }

  .rank-size-table-row[data-group="negative"] .rank-size-indicator {
    background: rgba(247, 111, 92, 0.08);
  }

  [data-rank-size-pairwise-table]:has(
      .rank-size-table-row[data-rank-size-state="consistent"]:hover
    ) .rank-size-table-row[data-rank-size-state="consistent"] {
    background: rgba(17, 17, 17, 0.065);
  }

  [data-rank-size-pairwise-table]:has(
      .rank-size-table-row[data-rank-size-state="inconsistent"]:hover
    ) .rank-size-table-row[data-rank-size-state="inconsistent"] {
    background: rgba(247, 111, 92, 0.1);
  }

  [data-rank-size-pairwise-table]:has(
      .rank-size-table-row[data-rank-size-state="consistent"]:hover
    ) .rank-size-table-row[data-rank-size-state="inconsistent"],
  [data-rank-size-pairwise-table]:has(
      .rank-size-table-row[data-rank-size-state="inconsistent"]:hover
    ) .rank-size-table-row[data-rank-size-state="consistent"] {
    opacity: 0.42;
  }

  [data-rank-size-pairwise-table]:has(
      .rank-size-table-row[data-rank-size-state="consistent"]:hover
    ) .rank-size-table-row[data-rank-size-state="consistent"] .rank-size-indicator {
    background: rgba(17, 17, 17, 0.09);
  }

  [data-rank-size-pairwise-table]:has(
      .rank-size-table-row[data-rank-size-state="inconsistent"]:hover
    ) .rank-size-table-row[data-rank-size-state="inconsistent"] .rank-size-indicator {
    background: rgba(247, 111, 92, 0.14);
  }

  @media (max-width: 640px) {
    .rank-size-product {
      grid-template-columns: 2.2ch 1.1ch 2.2ch 1.1ch 2.2ch;
    }
  }
</style>
